# Optional per-deploy overrides for `docker compose up`.
#
# `docker compose up -d` works out of the box without this file — every
# variable below has a sensible default in compose.yml. Copy to .env
# and edit only the things you actually want to change.
#
#   cp .env.example .env && $EDITOR .env

# Auth bypass. When set (and non-empty), every header-less request
# becomes this user. Default is empty → real auth required.
#
# The only multi-user auth path prep offers is Tailscale Serve — it
# injects per-user identity headers (Tailscale-User-Login) that prep
# maps to user_id. Without tailscale, prep returns 401 unless this
# bypass is set.
#
# Set to 'guest' (or your tailnet email) for a single-user single-
# machine bring-up before tailscale is in front of the deploy. Remove
# entirely once tailscale is fronting it.
# PREP_DEFAULT_USER=guest

# URL prefix the app generates. Empty = serves at root (good for
# direct-port access). Set to /prep (or whatever) when path-mounting
# behind tailscale serve --set-path or another reverse proxy.
# ROOT_PATH=

# Host port the prep app listens on. The container always binds 8082
# internally; this is the host-side port mapped to it. Default: 8082.
# PREP_HOST_PORT=8082

# Volume namespace. The compose names data volumes `${ENV_NAME}-data`
# and `${ENV_NAME}-agent-data`. Only matters if you run two prep
# stacks on the same docker host — staging + prod, dev + prod, etc.
# Default: 'prep'.
# ENV_NAME=prep

# Internal temporal namespace. Different stacks on the same host
# should differ; a single deployment can use anything. Default: 'prep'.
# TEMPORAL_NAMESPACE=prep

# IANA "sub" claim sent to push services on web push notifications.
# Recommended in production so a push provider can reach the operator
# if there's an operational issue.
# PREP_VAPID_SUB=mailto:you@example.com
