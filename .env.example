# Environment for `docker compose up`. Copy to `.env` and edit.
#
# .env is gitignored — it's per-deployment config. .env.example is
# committed.

# Host port the prep app listens on. The compose maps this → 8082
# inside the container. For staging on the macmini we use 8082; for
# prod on the same box we'd use 8081 (with a separate compose project
# name, see -p flag below).
PREP_HOST_PORT=8082

# What URL prefix the app is served at. Should match what tailscale
# serve / your reverse proxy mounts the app at. Leave empty if served
# at the root.
ROOT_PATH=/prep-staging

# Temporal namespace this deployment uses. Different staging vs prod
# so workflow histories don't collide if they share a server.
TEMPORAL_NAMESPACE=prep-staging

# AUTH BYPASS for local dev / single-user setups: set to your tailscale
# email and every header-less request becomes that user. Comment out
# in real prod where Tailscale Serve injects identity headers per-user.
PREP_DEFAULT_USER=you@example.com

# Optional: VAPID "sub" claim sent to push services on web push
# notifications. Recommended in prod, optional in dev.
# PREP_VAPID_SUB=mailto:you@example.com
