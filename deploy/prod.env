# Tracked prod deploy config. Loaded by `make deploy-prod`.
#
# Same shape as deploy/staging.env — see that file's preamble for the
# layering rule.

# Tailscale Serve at /prep maps to host port 8081.
PREP_HOST_PORT=8081
ROOT_PATH=/prep

# Internal temporal namespace.
TEMPORAL_NAMESPACE=prep

# Volume namespace → 'prod-data' + 'prod-agent-data'. Distinct from
# staging's 'prep-data' / 'prep-agent-data' so the two stacks share
# zero state on the same docker host.
ENV_NAME=prod

# Push contact — surfaces in the VAPID JWT 'sub' claim, so push
# providers can reach the operator if they need to. Override with a
# real address in a local .env if you want.
PREP_VAPID_SUB=mailto:noreply@example.com

# PREP_DEFAULT_USER is passed as empty by the `make deploy-prod` recipe
# so prod enforces real Tailscale identity on every request. See the
# matching note in deploy/staging.env for why it's done in the recipe
# (shell precedence) instead of here.
