# Tracked staging deploy config. Loaded by `make deploy-stag`.
#
# What lives here: the *deploy shape* (network, namespace) — not
# secrets, not per-contributor identity. Anything you want to override
# on a single machine goes in a local `.env` (gitignored), which
# layers on top.

# Container exposes 8082 internally; this is the host-side port.
PREP_HOST_PORT=8082

# URL prefix the app generates. Tailscale Serve at /prep-staging strips
# the prefix when forwarding, so uvicorn needs --root-path to match.
ROOT_PATH=/prep-staging

# Internal temporal namespace. Distinct from prod's so the two stacks
# don't share workflow state inside their own devservers.
TEMPORAL_NAMESPACE=prep-staging

# ENV_NAME (volume namespace) deliberately unset — defaults to 'prep'
# so volumes are 'prep-data' + 'prep-agent-data'. Matches what the
# pre-split staging stack used; existing staging data is preserved.

# PREP_DEFAULT_USER is passed as empty by the `make deploy-stag` recipe
# (via a `PREP_DEFAULT_USER=` prefix on the command line) so that real
# Tailscale identity is required — same behavior as prod. We don't set
# it here because shell-env vars take precedence over --env-file values
# in compose, and the Makefile's `export PREP_DEFAULT_USER ?=
# dev@example.com` (for `make dev`) would otherwise leak in.
