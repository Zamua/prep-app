# Staging env for the artifact-based deploy pipeline.
#
# Install: copy to ~/Library/prep/config/staging.env (the wrapper script
# sources from there, NOT from the repo, so config survives any artifact
# promote and any repo `git clean`).
#
#   mkdir -p ~/Library/prep/config
#   cp config/staging.env.example ~/Library/prep/config/staging.env
#   $EDITOR ~/Library/prep/config/staging.env
#
# Sourced by scripts/run-prep.sh in `bash -c "set -a; source <file>"`,
# so $HOME and other shell expansions work — paths don't need to be
# literal absolutes.

PORT=8082
ROOT_PATH=/prep-staging
TEMPORAL_NAMESPACE=prep-staging
TEMPORAL_HOST_PORT=127.0.0.1:7233

# data + secrets live OUTSIDE any artifact so they survive promotes.
PREP_DB_PATH=$HOME/Library/prep/data/staging/data.sqlite
PREP_VAPID_KEYS_PATH=$HOME/Library/prep/data/staging/vapid-keys.json
PREP_VAPID_PEM_PATH=$HOME/Library/prep/data/staging/vapid-private.pem

# Local AI CLI. Backwards-compat alias CLAUDE_BIN is still honored.
PREP_AGENT_BIN=$HOME/.local/bin/claude

# Auth bypass: every header-less request becomes this user. Convenient
# for staging where you're the only user; remove in prod.
PREP_DEFAULT_USER=you@example.com
