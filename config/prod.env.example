# Prod env for the artifact-based deploy pipeline.
#
# Install: copy to ~/Library/prep/config/prod.env.
#
# Notable differences from staging:
#   • PORT=8081 (canonical prod port)
#   • ROOT_PATH=/prep
#   • TEMPORAL_NAMESPACE=prep
#   • PREP_DEFAULT_USER UNSET — every request must come with a real
#     Tailscale-User-Login header. Setting it in prod would silently
#     authenticate every header-less request as that single user.

PORT=8081
ROOT_PATH=/prep
TEMPORAL_NAMESPACE=prep
TEMPORAL_HOST_PORT=127.0.0.1:7233

PREP_DB_PATH=$HOME/Library/prep/data/prod/data.sqlite
PREP_VAPID_KEYS_PATH=$HOME/Library/prep/data/prod/vapid-keys.json
PREP_VAPID_PEM_PATH=$HOME/Library/prep/data/prod/vapid-private.pem

PREP_AGENT_BIN=$HOME/.local/bin/claude

# Optional VAPID "sub" claim (push services use this as a contact
# address for operational issues). Recommended for prod.
# PREP_VAPID_SUB=mailto:you@example.com
