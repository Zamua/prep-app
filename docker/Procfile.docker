# Procfile for the docker-compose deploy. Three processes, all in
# one container, supervised by goreman. The dev-time Procfile and the
# v0.9 launchd-managed Procfile.deployed are now legacy; this is the
# canonical shape going forward.
#
# All values come from env (see Dockerfile.prep ENV defaults +
# docker-compose.yml env_file directive).

temporal: sh -c 'mkdir -p /data/temporal /data/prep && exec temporal server start-dev --ip 127.0.0.1 --port 7233 --ui-port 8233 --db-filename /data/temporal/temporal.db --namespace $TEMPORAL_NAMESPACE --log-level warn'
app: .venv/bin/uvicorn app:app --host $HOST --port $PORT --no-access-log --root-path $ROOT_PATH
worker: ./worker-go/bin/worker
